<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>React Counter</title>
  </head>
  <body>
    <div id="root"></div>
  </body>

  <script src="https://unpkg.com/react@17.0.2/umd/react.production.min.js"></script>
  <script src="https://unpkg.com/react-dom@17.0.2/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

  <script type="text/babel">
    const root = document.getElementById("root");

    function Reset(prop) {
      const { amount, setAmount } = prop;
      const reset = () => {
        setAmount(0);
      };
      return <button onClick={reset}>Reset</button>;
    }
    function Invert(prop) {
      const { setAmount, setInverted } = prop;
      const onInvert = () => {
        setAmount(0);
        setInverted((current) => !current);
      };
      return <button onClick={onInvert}>Invert</button>;
    }

    function MinutesAndHours() {
      const [amount, setAmount] = React.useState(0);
      const [inverted, setInverted] = React.useState(false);
      const onChange = (event) => {
        setAmount(event.target.value);
      };

      return (
        <div>
          <div>
            <label htmlFor="minutes">Minutes</label>
            <input
              value={inverted ? amount * 60 : amount}
              onChange={onChange}
              onFocus={() => setAmount("")}
              id="minutes"
              type="number"
              placeHolder="Minutes"
              disabled={inverted}
            />
          </div>
          <div>
            <label htmlFor="hours">Hours</label>
            <input
              value={!inverted ? Math.round(amount / 60) : amount}
              onChange={onChange}
              onFocus={() => setAmount("")}
              id="hours"
              type="number"
              placeHolder="Hours"
              disabled={!inverted}
            />
          </div>
          {/* <button onClick={reset}>Reset</button> */}
          {/* <button onClick={onInvert}>Invert</button> */}
          <Reset setAmount={setAmount} />
          <Invert setAmount={setAmount} setInverted={setInverted} />
        </div>
      );
    }

    function KmAndMiles() {
      const [amount, setAmount] = React.useState(0);
      const [inverted, setInverted] = React.useState(false);
      const onChange = (event) => {
        setAmount(event.target.value);
      };
      return (
        <div>
          <div>
            <label for="km">Km</label>
            <input
              type="number"
              id="km"
              value={inverted ? amount / 0.621371 : amount}
              onChange={onChange}
              disabled={inverted}
              onFocus={() => setAmount("")}
            />
          </div>
          <div>
            <label for="miles">Miles</label>
            <input
              type="number"
              id="miles"
              value={!inverted ? amount * 0.621371 : amount}
              onChange={onChange}
              disabled={!inverted}
              onFocus={() => setAmount("")}
            />
          </div>
          <Reset setAmount={setAmount} />
          <Invert setAmount={setAmount} setInverted={setInverted} />
        </div>
      );
    }

    function App() {
      const [index, setIndex] = React.useState("-1");
      const onChange = (event) => {
        setIndex(event.target.value);
      };
      return (
        <div>
          <h1>Super Converter</h1>
          <select value={index} onChange={onChange}>
            <option value="-1">Select your units</option>
            <option value="0">Minutes & Hours</option>
            <option value="1">Km & Miles</option>
          </select>
          <hr />
          {index === "-1" ? "Please select your units" : null}
          {index === "0" ? <MinutesAndHours /> : null}
          {index === "1" ? <KmAndMiles /> : null}
        </div>
      );
    }

    ReactDOM.render(<App />, root);
  </script>
</html>
